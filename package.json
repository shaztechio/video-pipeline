{
  "name": "video-pipeline",
  "version": "1.0.3",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/editor",
    "dev": "npm run dev -w packages/editor",
